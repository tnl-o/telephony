# LDAP Configuration
LDAP_URI=ldap://your-ad-controller.local
LDAP_BASE_DN=DC=company,DC=local
LDAP_BIND_DN=CN=ServiceUser,CN=Users,DC=company,DC=local
LDAP_BIND_PASSWORD=YourPassword
LDAP_USER_ATTRIBUTE=sAMAccountName
LDAP_DISPLAY_NAME_ATTRIBUTE=displayName
LDAP_EMAIL_ATTRIBUTE=mail
LDAP_DEPARTMENT_ATTRIBUTE=department

# FreePBX Configuration
FREEPBX_IP=192.168.1.100
FREEPBX_SIP_PORT=5060

# Application Settings
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-session-secret-change-this-in-production
NODE_ENV=production

# Network Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# FreeSWITCH Settings
FS_EVENT_HOST=100.64.0.10
FS_EVENT_PORT=8021
FS_EVENT_PASSWORD=ClueCon
FS_WSS_PORT=7443

# Internal Network (CGNAT)
DOCKER_SUBNET=100.64.0.0/24
BACKEND_IP=100.64.0.20
FREESWITCH_IP=100.64.0.10
FRONTEND_IP=100.64.0.30
NGINX_IP=100.64.0.5
