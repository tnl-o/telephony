<?xml version="1.0" encoding="utf-8"?>
<!-- Dialplan: Internal and External Routing -->

<include>
  <!-- Internal: 1000–5999 — звонки между пользователями через WSS -->
  <extension name="internal_call">
    <condition field="destination_number" expression="^([1-5][0-9]{3})$">
      <action application="set" data="hangup_after_bridge=true"/>
      <action application="ring_ready"/>
      <!-- sofia/internal — доставит INVITE через тот же WSS транспорт, на котором зарегистрирован абонент -->
      <action application="bridge" data="{rtp_secure_media=true,media_webrtc=true}sofia/internal/${destination_number}@$${domain_name}"/>
    </condition>
  </extension>

  <!-- External Calls: Prefix 9 + Number (via FreePBX Trunk) -->
  <extension name="external_call">
    <condition field="destination_number" expression="^9(.+)$">
      <action application="answer"/>
      <action application="set" value="effective_caller_id_number=${caller_id_number}"/>
      <action application="set" value="effective_caller_id_name=${caller_id_name}"/>
      <action application="bridge" value="sofia/gateway/freepbx_trunk/$1"/>
    </condition>
  </extension>

  <!-- Emergency Numbers (Direct to Trunk without prefix) -->
  <extension name="emergency_call">
    <condition field="destination_number" expression="^(101|102|103|112)$">
      <action application="answer"/>
      <action application="bridge" value="sofia/gateway/freepbx_trunk/${destination_number}"/>
    </condition>
  </extension>

  <!-- Номера вне внутреннего диапазона / без префикса 9 / не экстренные — не пересекаться с internal_call -->
  <extension name="invalid_number">
    <condition field="destination_number" expression="^(?!([1-5][0-9]{3})$|9\d+$|101$|102$|103$|112$).+$">
      <action application="answer"/>
      <action application="playback" value="tone_stream://%(200,0,500);%(200,0,700)"/>
      <action application="hangup"/>
    </condition>
  </extension>
</include>
