<?xml version="1.0" encoding="utf-8"?>
<!-- Internal SIP Profile: WebRTC Clients -->
<!-- WSS :7443 с хоста (Docker publish); ice-lite + apply-candidate-acl=lan для ICE за Docker/NAT -->

<profile name="internal">
  <!-- IP Binding: Docker CGNAT Address -->
  <settings>
    <param name="dialplan" value="XML"/>
    <param name="context" value="default"/>
    <param name="auth-calls" value="true"/>
    <param name="debug" value="0"/>
    <param name="sip-port" value="5060"/>
    <!-- WSS TLS на :7443 (к nginx или напрямую) -->
    <param name="tls" value="true"/>
    <param name="tls-bind-params" value="transport=wss"/>
    <param name="tls-cert-dir" value="/etc/freeswitch/tls"/>
    <param name="tls-verify-date" value="false"/>
    <param name="apply-inbound-acl" value="lan"/>
    <param name="apply-register-acl" value="lan"/>
    <param name="apply-nat-acl" value="nat.auto_rfc1918"/>
    <!-- Регистрация с Contact за nginx (если кто-то ещё использует nginx): доставка INVITE на тот же сокет. -->
    <param name="NDLB-received-in-nat-reg-contact" value="true"/>
    <!-- Aggressive NAT detection: игнорировать mDNS-подобные Contact (.invalid, .local) -->
    <param name="aggressive-nat-detection" value="true"/>
    
    <!-- NAT Handling -->
    <param name="ext-rtp-ip" value="$${external_rtp_ip}"/>
    <param name="ext-sip-ip" value="$${external_sip_ip}"/>
    <param name="rtp-ip" value="$${local_ip_v4}"/>
    <param name="sip-ip" value="$${local_ip_v4}"/>
    
    <!-- Codecs: Opus First, then G.711 fallback -->
    <param name="inbound-codec-prefs" value="$${global_codec_prefs}"/>
    <param name="outbound-codec-prefs" value="$${global_codec_prefs}"/>
    
    <!-- Timers and Sessions -->
    <param name="max-authentications" value="1000"/>
    <param name="max-registrations" value="5000"/>
    <param name="delete-subs-on-register" value="false"/>
    <!-- Domain: должен совпадать с $${domain_name} (100.64.1.10) — иначе bridge sofia/internal/XXXX@domain не найдёт регистрацию -->
    <param name="force-register-domain" value="$${domain}"/>
    <param name="force-register-db-domain" value="$${domain}"/>
    <param name="all-reg-options-in-event" value="true"/>
    
    <!-- WebSocket Settings -->
    <param name="wss-binding" value=":7443"/>
    <param name="ws-connect-timeout" value="30"/>
    <param name="ws-read-timeout" value="30"/>
    <param name="ws-write-timeout" value="30"/>

    <!-- ICE-Lite: FS объявляет a=ice-lite в SDP.
         Браузер (full ICE agent) сам инициирует connectivity checks на ext-rtp-ip (192.168.0.18:PORT).
         Docker DNAT пробрасывает на контейнер. FS отвечает на checks — не ищет кандидатов сам.
         Без ice-lite FS делает selection из браузерских кандидатов и падает с
         "no suitable candidates found" → INCOMPATIBLE_DESTINATION 488, потому что
         192.168.0.x недостижим из контейнера 100.64.1.0/24 для ICE connectivity checks. -->
    <param name="ice-lite" value="true"/>
    <!-- Принимать ICE-кандидаты только из LAN-диапазона (нашей acl.conf "lan") -->
    <param name="apply-candidate-acl" value="lan"/>
  </settings>

  <!-- Gateways: External Trunk -->
  <gateways>
    <X-PRE-PROCESS cmd="include" data="../gateways/*.xml"/>
  </gateways>

  <!-- Aliases -->
  <aliases>
  </aliases>

  <!-- Domains -->
  <domains>
    <domain name="all" alias="false" parse="true"/>
  </domains>

  <!-- Profiles -->
  <profiles>
    <profile name="default">
      <param name="codec-prefs" value="$${global_codec_prefs}"/>
      <param name="realm" value="$${domain}"/>
      <param name="challenge-realm" value="auto_from"/>
      <param name="dtmf-type" value="info"/>
      <param name="caller-id-type" value="pidf"/>
      <param name="presence-probe-interval" value="30"/>
      <param name="send-message-query-on-ping" value="true"/>
    </profile>
  </profiles>
</profile>
