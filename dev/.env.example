# Режим без LDAP: пары логин:пароль через запятую (логин в нижнем регистре при проверке).
AUTH_MODE=simple
DEV_USERS=demo:demo,alice:alice123,bob:bob123

# Общий SIP-пароль для dev; должен совпадать с генерацией dev/freeswitch/directory/local-extensions.xml (по умолчанию devsip).
DEV_SIP_PASSWORD=devsip

NODE_ENV=development
PORT=3000

# Не задавайте SIP_WSS_URL для доступа с других ПК — пусть backend строит URL из Host (см. backend buildSipWssUrl).
# SIP_WSS_URL=wss://192.168.0.11:8443/sip

# LAN-IP компьютера с Docker. Для звонков с других ПК: SDP будет с этим адресом (иначе RTP на 100.64.x.x).
# В брандмауэре Windows разрешите входящие UDP 16384–16448.
PUBLIC_HOST=192.168.0.11

# Необязательно: если заголовки X-Forwarded-* не доходят, можно задать хост для WSS в ответе логина (иначе берётся Host запроса).
# WSS_PUBLIC_HOST=192.168.1.10
